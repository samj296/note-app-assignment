        <%- include("partials/header", {
            title: "Home - TwoNote",
            page: `Welcome ${username}`
       }) %>

            <div id = "book-div">
                
                <p>📚 Books</p>
                <div>
                    <input>
                    <button class = "btn btn btn-outline-light">Add Book</button>
                </div>
                <ul>
                    
                    <%  books.forEach(book => { %>
                        <li>
                            📖<button class = "btn btn-outline-dark" type = "button" 
                            data-id = "<%= book.id %>"> <%= book.title %> </button>
                        </li>
                    <% }); %>
                </ul>
                
            </div>
            <div id = "note-div">
                <p> Select the book to view notes</p>
            </div>

            <script type = "module" src = "/script/homepageScript.js"></script>
       </body>
    </html>